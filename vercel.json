{
  "version": 2,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/src/index.html" },
    { "source": "/inicio", "destination": "/src/index.html" },
    { "source": "/propostas", "destination": "/src/index.html" },
    { "source": "/clientes", "destination": "/src/index.html" },
    { "source": "/funcionarios", "destination": "/src/index.html" },
    { "source": "/contracheque", "destination": "/src/index.html" },
    { "source": "/balanco", "destination": "/src/index.html" },
    { "source": "/impostos", "destination": "/src/index.html" },
    { "source": "/contratos", "destination": "/src/index.html" },
    { "source": "/imoveis-alugados", "destination": "/src/index.html" },
    { "source": "/exportados", "destination": "/src/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
