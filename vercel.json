{
  "version": 2,
  "trailingSlash": false,
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/app\\.js$", "dest": "/src/app.js" },
    { "src": "^/styles\\.css$", "dest": "/src/styles.css" },
    { "src": "^/assets/(.*)$", "dest": "/src/assets/$1" },
    { "src": "^/$", "dest": "/src/index.html" },
    {
      "src": "^/(inicio|propostas|clientes|funcionarios|contracheque|balanco|impostos|contratos|imoveis-alugados|exportados)(?:/.*)?$",
      "dest": "/src/index.html"
    },
    { "src": "^(.*)$", "dest": "/src/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
